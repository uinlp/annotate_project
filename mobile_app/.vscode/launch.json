{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "uinlp_annotate",
            "request": "launch",
            "type": "dart",
            "args": [
                "--dart-define-from-file=${workspaceFolder}/.env.dev"
            ]
        },
        {
            "name": "uinlp_annotate (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "args": [
                "--dart-define-from-file=${workspaceFolder}/.env.dev"
            ]
        },
        {
            "name": "uinlp_annotate (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "args": [
                "--dart-define-from-file=${workspaceFolder}/.env.prod"
            ]
        },
        {
            "name": "mobile_app (Flutter)",
            "program": "lib/main.dart",
            "request": "launch",
            "type": "dart"
        }
    ]
}